<section id="inicio" class="hero-section d-flex align-items-center">
  <div class="container text-center py-5">
    <div class="mb-4">
      <i class="bi bi-mountains display-1 text-warning"></i>
    </div>

    <h1 class="display-3 fw-bold text-dark mb-2"><%= t('website.hero.title') %></h1>
    <p class="lead text-warning fw-semibold mb-4"><%= t('website.hero.tagline') %></p>
    <p class="mx-auto mb-5 text-muted" style="max-width: 700px;">
      <%= t('website.hero.description') %>
    </p>

    <div class="d-flex justify-content-center gap-3 mb-5 flex-wrap">
      <a href="#cursos" class="btn btn-warning btn-lg px-4">
        <i class="bi bi-music-note-beamed me-2"></i><%= t('website.hero.cta_classes') %>
      </a>
      <a href="#contacto" class="btn btn-outline-warning btn-lg px-4">
        <i class="bi bi-envelope me-2"></i><%= t('website.hero.cta_contact') %>
      </a>
    </div>

    <div class="row g-4 mt-4">
      <div class="col-md-4">
        <div class="card h-100 border-warning highlight-card">
          <div class="card-body text-center p-4">
            <i class="bi bi-people display-5 text-warning mb-3"></i>
            <h5 class="card-title"><%= t('website.hero.highlights.community.title') %></h5>
            <p class="card-text text-muted"><%= t('website.hero.highlights.community.description') %></p>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card h-100 border-warning highlight-card">
          <div class="card-body text-center p-4">
            <i class="bi bi-heart display-5 text-warning mb-3"></i>
            <h5 class="card-title"><%= t('website.hero.highlights.heart.title') %></h5>
            <p class="card-text text-muted"><%= t('website.hero.highlights.heart.description') %></p>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card h-100 border-warning highlight-card">
          <div class="card-body text-center p-4">
            <i class="bi bi-stars display-5 text-warning mb-3"></i>
            <h5 class="card-title"><%= t('website.hero.highlights.ages.title') %></h5>
            <p class="card-text text-muted"><%= t('website.hero.highlights.ages.description') %></p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
