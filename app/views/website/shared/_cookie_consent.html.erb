<div id="cookie-consent-banner" class="cookie-banner" style="display: none;">
  <div class="cookie-banner__content">
    <p class="cookie-banner__text">
      <%= t('website.cookie_consent.message') %>
      <%= link_to t('website.cookie_consent.privacy_link'), website.datenschutz_path, class: "cookie-banner__link" %>
    </p>
    <div class="cookie-banner__actions">
      <button id="cookie-reject" class="cookie-banner__btn cookie-banner__btn--reject">
        <%= t('website.cookie_consent.reject') %>
      </button>
      <button id="cookie-accept" class="cookie-banner__btn cookie-banner__btn--accept">
        <%= t('website.cookie_consent.accept') %>
      </button>
    </div>
  </div>
</div>
