<% if @enrollment.trial? %>
  <h2>Nueva clase de prueba</h2>

  <% if @session_detail %>
    <table cellpadding="8" cellspacing="0" style="border: 1px solid #ede4d4; border-radius: 8px; background: #faf6ef; margin-bottom: 16px; width: 100%;">
      <tr>
        <td style="border-bottom: 1px solid #ede4d4;">
          <strong>Clase:</strong> <%= @session_detail.title %>
        </td>
      </tr>
      <tr>
        <td style="border-bottom: 1px solid #ede4d4;">
          <strong>Profesor/a:</strong> <%= @session_detail.facilitator&.name || "Sin asignar" %>
        </td>
      </tr>
      <tr>
        <td style="border-bottom: 1px solid #ede4d4;">
          <strong>Grupo:</strong> <%= @session_detail.targetable&.name %>
          <% if @session_detail.targetable.respond_to?(:available_slots) && @session_detail.targetable.capacity %>
            (<%= @session_detail.targetable.participants.size %>/<%= @session_detail.targetable.capacity %> estudiantes)
          <% end %>
        </td>
      </tr>
      <% if @session_record %>
        <tr>
          <td style="border-bottom: 1px solid #ede4d4;">
            <strong>Fecha:</strong> <%= I18n.l(@session_record.start_time.to_date, format: :long) %>
          </td>
        </tr>
        <tr>
          <td>
            <strong>Horario:</strong> <%= @session_record.start_time.strftime("%H:%M") %> · <%= @session_record.duration %> minutos
          </td>
        </tr>
      <% end %>
    </table>
  <% end %>

  <hr>
<% else %>
  <h2>Nuevo contacto</h2>
<% end %>

<% if @enrollment.trial? %>
  <p><strong>Alumno/a:</strong> <%= @enrollment.student_name %></p>
  <p><strong>Edad:</strong> <%= @enrollment.student_age %></p>
<% end %>
<p><strong>Contacto:</strong> <%= @enrollment.contact_name %></p>
<p><strong>Email:</strong> <%= @enrollment.email %></p>
<% if @enrollment.phone.present? %>
  <p><strong>Teléfono:</strong> <%= @enrollment.phone %></p>
<% end %>
<% if @enrollment.comments.present? %>
  <h3><%= @enrollment.trial? ? "Comentarios:" : "Mensaje:" %></h3>
  <p><%= simple_format(@enrollment.comments) %></p>
<% end %>
