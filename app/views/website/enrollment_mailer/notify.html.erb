<% if @enrollment.trial? %>
  <h2>Nueva clase de prueba</h2>

  <p><strong>Clase:</strong> Sesión #<%= @enrollment.session_detail_id %> — Horario #<%= @enrollment.session_record_id %></p>
  <hr>
<% else %>
  <h2>Nueva inscripción</h2>
<% end %>

<p><strong>Alumno/a:</strong> <%= @enrollment.student_name %></p>
<p><strong>Edad:</strong> <%= @enrollment.student_age %></p>
<p><strong>Contacto:</strong> <%= @enrollment.contact_name %></p>
<p><strong>Email:</strong> <%= @enrollment.email %></p>
<% if @enrollment.phone.present? %>
  <p><strong>Teléfono:</strong> <%= @enrollment.phone %></p>
<% end %>
<% unless @enrollment.trial? %>
  <p><strong>Idioma preferido:</strong> <%= @enrollment.preferred_language %></p>
  <p><strong>Tipo de clase:</strong> <%= @enrollment.class_type %></p>
  <p><strong>Disponibilidad:</strong> <%= @enrollment.availability %></p>
<% end %>
<% if @enrollment.comments.present? %>
  <h3>Comentarios:</h3>
  <p><%= simple_format(@enrollment.comments) %></p>
<% end %>
