<% content_for :title, t('website.trial_classes.title') %>

<%# Mini Hero %>
<section class="trial-hero">
  <div class="container text-center">
    <span class="section-label"><%= t('website.trial_classes.label') %></span>
    <h1 class="section-title mb-3"><%= t('website.trial_classes.heading') %></h1>
    <p class="trial-hero__subtitle"><%= t('website.trial_classes.subtitle') %></p>
  </div>
</section>

<%# Flash Messages %>
<% if flash[:notice] || flash[:alert] %>
  <section class="trial-flash-section">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-lg-8">
          <% if flash[:notice] %>
            <div class="alert alert-success d-flex align-items-center" role="alert">
              <i class="bi bi-check-circle-fill me-2"></i>
              <%= flash[:notice] %>
            </div>
          <% end %>
          <% if flash[:alert] %>
            <div class="alert alert-danger d-flex align-items-center" role="alert">
              <i class="bi bi-exclamation-circle-fill me-2"></i>
              <%= flash[:alert] %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </section>
<% end %>

<%# Trial Class Cards %>
<section class="trial-classes-section">
  <div class="container">
    <% if @trial_classes.any? %>
      <div class="row g-4">
        <% @trial_classes.each_with_index do |trial_class, class_index| %>
          <% sessions = trial_class["sessions"] %>
          <% next if sessions.empty? %>
          <% first_session = sessions.first %>
          <% first_date = Date.parse(first_session["date"]) %>
          <% day_name = l(first_date, format: "%A") %>
          <% available = trial_class["available_slots"] %>
          <% remaining_sessions = sessions.drop(1) %>

          <div class="col-lg-6 reveal">
            <div class="trial-card">
              <div class="trial-card__header">
                <div class="trial-card__icon">
                  <i class="bi bi-music-note-beamed"></i>
                </div>
                <div>
                  <h3 class="trial-card__title"><%= trial_class["title"] %></h3>
                  <% if trial_class["facilitator"] %>
                    <p class="trial-card__facilitator"><%= trial_class["facilitator"] %></p>
                  <% end %>
                </div>
              </div>

              <div class="trial-card__body">
                <%# Schedule pattern banner %>
                <div class="trial-pattern">
                  <i class="bi bi-arrow-repeat"></i>
                  <%= t('website.trial_classes.every_day', day: day_name) %> · <%= first_session["time"] %> · <%= t('website.trial_classes.minutes', count: first_session["duration"]) %>
                </div>

                <%# Next available session — hero treatment %>
                <p class="trial-card__next-label"><%= t('website.trial_classes.next_class') %></p>
                <div class="trial-next">
                  <div class="trial-next__info">
                    <div class="trial-next__date">
                      <%= l(first_date, format: :long).capitalize %>
                    </div>
                    <% if available && available <= 0 %>
                      <div class="trial-next__slots trial-next__slots--full">
                        <i class="bi bi-circle-fill me-1"></i><%= t('website.trial_classes.group_full') %>
                      </div>
                    <% elsif available && available <= 1 %>
                      <div class="trial-next__slots trial-next__slots--low">
                        <i class="bi bi-circle-fill me-1"></i><%= t('website.trial_classes.last_slot') %>
                      </div>
                    <% elsif available && available <= 2 %>
                      <div class="trial-next__slots trial-next__slots--medium">
                        <i class="bi bi-circle-fill me-1"></i><%= t('website.trial_classes.slots_available', count: available) %>
                      </div>
                    <% elsif available %>
                      <div class="trial-next__slots trial-next__slots--plenty">
                        <i class="bi bi-circle-fill me-1"></i><%= t('website.trial_classes.slots_available', count: available) %>
                      </div>
                    <% end %>
                  </div>
                  <% if available.nil? || available > 0 %>
                    <button type="button"
                            class="btn btn-andes trial-next__btn"
                            data-class-title="<%= trial_class["title"] %>"
                            data-facilitator="<%= trial_class["facilitator"] %>"
                            data-date="<%= l(first_date, format: :long) %>"
                            data-time="<%= first_session["time"] %>"
                            data-duration="<%= first_session["duration"] %>"
                            data-session-detail-id="<%= trial_class["id"] %>"
                            data-session-record-id="<%= first_session["id"] %>"
                            onclick="selectTrialSession(this)">
                      <%= t('website.trial_classes.book_this_class') %>
                    </button>
                  <% end %>
                </div>

                <%# More dates — progressive disclosure %>
                <% if remaining_sessions.any? && (available.nil? || available > 0) %>
                  <button type="button" class="trial-more-toggle" onclick="toggleMoreDates(this, 'more-dates-<%= class_index %>')">
                    <i class="bi bi-chevron-right"></i>
                    <%= t('website.trial_classes.more_dates', count: remaining_sessions.size) %>
                  </button>

                  <div id="more-dates-<%= class_index %>" class="trial-more-dates" style="display: none;">
                    <div class="trial-dates-grid">
                      <% remaining_sessions.each do |session| %>
                        <% date = Date.parse(session["date"]) %>
                        <button type="button"
                                class="trial-date-pill"
                                data-class-title="<%= trial_class["title"] %>"
                                data-facilitator="<%= trial_class["facilitator"] %>"
                                data-date="<%= l(date, format: :long) %>"
                                data-time="<%= session["time"] %>"
                                data-duration="<%= session["duration"] %>"
                                data-session-detail-id="<%= trial_class["id"] %>"
                                data-session-record-id="<%= session["id"] %>"
                                onclick="selectTrialSession(this)">
                          <span class="trial-date-pill__day"><%= l(date, format: "%a") %></span>
                          <span class="trial-date-pill__date"><%= l(date, format: "%d %b") %></span>
                        </button>
                      <% end %>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>

      <%# Sign-up Form (hidden by default) %>
      <div id="trial-signup-form" class="trial-signup" style="display: none;">
        <div class="row justify-content-center">
          <div class="col-lg-8">
            <div class="enrollment-form-card">
              <%# Selected session summary %>
              <div id="trial-selected-summary" class="trial-selected-summary mb-4">
                <div class="trial-selected-summary__content">
                  <div class="trial-selected-summary__class" id="summary-class"></div>
                  <div class="trial-selected-summary__session" id="summary-session"></div>
                  <a href="#" id="summary-change-link" class="trial-selected-summary__change"><%= t('website.trial_classes.change_session') %></a>
                </div>
              </div>

              <%= form_with url: website.enrollments_path, scope: :enrollment, local: true, class: "form-andes", id: "trial-form" do |f| %>
                <%= f.hidden_field :source, value: "trial", id: "enrollment_source" %>
                <%= f.hidden_field :session_detail_id, value: "", id: "enrollment_session_detail_id" %>
                <%= f.hidden_field :session_record_id, value: "", id: "enrollment_session_record_id" %>

                <div class="row g-3">
                  <div class="col-md-6">
                    <%= f.label :student_name, "#{t('website.enrollment.form.student_name')} *", class: "form-label" %>
                    <%= f.text_field :student_name, class: "form-control", placeholder: t('website.enrollment.form.placeholders.student_name'), required: true %>
                  </div>
                  <div class="col-md-6">
                    <%= f.label :student_age, "#{t('website.enrollment.form.student_age')} *", class: "form-label" %>
                    <%= f.text_field :student_age, class: "form-control", placeholder: t('website.enrollment.form.placeholders.student_age'), required: true %>
                  </div>
                </div>

                <div class="row g-3 mt-1">
                  <div class="col-md-6">
                    <%= f.label :contact_name, "#{t('website.enrollment.form.contact_name')} *", class: "form-label" %>
                    <%= f.text_field :contact_name, class: "form-control", placeholder: t('website.enrollment.form.placeholders.contact_name'), required: true %>
                  </div>
                  <div class="col-md-6">
                    <%= f.label :email, "#{t('website.enrollment.form.email')} *", class: "form-label" %>
                    <%= f.email_field :email, class: "form-control", placeholder: t('website.enrollment.form.placeholders.email'), required: true %>
                  </div>
                </div>

                <div class="mt-3">
                  <%= f.label :phone, t('website.enrollment.form.phone'), class: "form-label" %>
                  <%= f.telephone_field :phone, class: "form-control", placeholder: t('website.enrollment.form.placeholders.phone') %>
                </div>

                <div class="mt-3">
                  <%= f.label :comments, t('website.enrollment.form.comments'), class: "form-label" %>
                  <%= f.text_area :comments, class: "form-control", rows: 3, placeholder: t('website.enrollment.form.placeholders.comments') %>
                </div>

                <div class="mt-3">
                  <div class="form-check">
                    <%= f.check_box :privacy_accepted, class: "form-check-input", required: true %>
                    <%= f.label :privacy_accepted, class: "form-check-label" do %>
                      <%= t('website.enrollment.form.privacy_accepted',
                            link: link_to(t('website.enrollment.form.privacy_link_text'),
                                          website.datenschutz_path,
                                          target: "_blank",
                                          rel: "noopener")).html_safe %>
                    <% end %>
                  </div>
                </div>

                <div class="mt-3">
                  <%= cloudflare_turnstile_tag %>
                </div>

                <div class="mt-4">
                  <%= f.submit t('website.trial_classes.submit'), class: "btn-submit" %>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </div>

    <% else %>
      <%# Empty state %>
      <div class="trial-empty reveal">
        <div class="trial-empty__icon">
          <i class="bi bi-music-note-list"></i>
        </div>
        <p class="trial-empty__message"><%= t('website.trial_classes.empty') %></p>
        <p class="trial-empty__hint"><%= t('website.trial_classes.empty_hint') %></p>
        <a href="<%= root_path(anchor: 'contacto') %>" class="btn btn-andes">
          <%= t('website.trial_classes.empty_cta') %>
        </a>
      </div>
    <% end %>
  </div>
</section>

<script>
  function selectTrialSession(button) {
    var form = document.getElementById('trial-signup-form');
    var summaryClass = document.getElementById('summary-class');
    var summarySession = document.getElementById('summary-session');

    document.getElementById('enrollment_session_detail_id').value = button.dataset.sessionDetailId;
    document.getElementById('enrollment_session_record_id').value = button.dataset.sessionRecordId;

    var classText = button.dataset.classTitle;
    if (button.dataset.facilitator) {
      classText += ' \u00B7 ' + button.dataset.facilitator;
    }
    summaryClass.textContent = classText;

    summarySession.textContent = button.dataset.date + ' \u00B7 ' + button.dataset.time + ' \u00B7 ' + button.dataset.duration + ' min';

    form.style.display = 'block';
    form.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  function toggleMoreDates(toggle, targetId) {
    var target = document.getElementById(targetId);
    var icon = toggle.querySelector('i');
    if (target.style.display === 'none') {
      target.style.display = 'block';
      icon.className = 'bi bi-chevron-down';
    } else {
      target.style.display = 'none';
      icon.className = 'bi bi-chevron-right';
    }
  }

  document.addEventListener('DOMContentLoaded', function() {
    var changeLink = document.getElementById('summary-change-link');
    if (changeLink) {
      changeLink.addEventListener('click', function(e) {
        e.preventDefault();
        document.getElementById('trial-signup-form').style.display = 'none';
        document.querySelector('.trial-classes-section').scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    }
  });
</script>
