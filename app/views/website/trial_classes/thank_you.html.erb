<% content_for :title, t('website.trial_classes.thank_you.title') %>

<section class="trial-hero">
  <div class="container text-center">
    <div class="trial-thank-you">
      <div class="trial-thank-you__icon">
        <i class="bi bi-check-circle"></i>
      </div>
      <h1 class="section-title mb-3"><%= t('website.trial_classes.thank_you.heading') %></h1>
      <p class="trial-hero__subtitle"><%= t('website.trial_classes.thank_you.message') %></p>
      <div class="mt-4">
        <a href="<%= root_path %>" class="btn btn-andes">
          <i class="bi bi-house me-2"></i><%= t('website.nav.home') %>
        </a>
      </div>
    </div>
  </div>
</section>
