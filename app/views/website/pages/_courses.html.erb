<section id="cursos" class="py-5">
  <div class="container">
    <div class="text-center mb-5">
      <h2 class="display-5 fw-bold"><%= t('website.courses.title') %></h2>
      <p class="lead text-muted"><%= t('website.courses.subtitle') %></p>
    </div>

    <div class="row g-4">
      <%# Piano Lessons %>
      <div class="col-lg-6">
        <div class="card h-100 border-warning shadow-sm">
          <div class="card-header bg-warning bg-opacity-10 border-warning">
            <h3 class="mb-0 d-flex align-items-center">
              <i class="bi bi-broadcast me-2 text-warning"></i>
              <%= t('website.courses.piano.title') %>
            </h3>
          </div>
          <div class="card-body p-4">
            <ul class="list-unstyled mb-4">
              <li class="mb-2">
                <i class="bi bi-people text-warning me-2"></i>
                <strong><%= t('website.courses.age_label') %>:</strong> <%= t('website.courses.piano.age') %>
              </li>
              <li class="mb-2">
                <i class="bi bi-globe text-warning me-2"></i>
                <strong><%= t('website.courses.languages_label') %>:</strong> <%= t('website.courses.piano.languages') %>
              </li>
              <li class="mb-2">
                <i class="bi bi-music-note text-warning me-2"></i>
                <strong><%= t('website.courses.modality_label') %>:</strong> <%= t('website.courses.piano.modality') %>
              </li>
              <li class="mb-2">
                <i class="bi bi-clock text-warning me-2"></i>
                <strong><%= t('website.courses.duration_label') %>:</strong> <%= t('website.courses.piano.duration') %>
              </li>
            </ul>

            <p><%= t('website.courses.piano.description_1') %></p>
            <p><%= t('website.courses.piano.description_2') %></p>

            <h5 class="d-flex align-items-center mt-4 mb-3">
              <i class="bi bi-currency-euro text-warning me-2"></i>
              <%= t('website.courses.pricing_label') %>
            </h5>
            <table class="table table-sm table-bordered">
              <thead class="table-warning">
                <tr>
                  <th><%= t('website.courses.duration_label') %></th>
                  <th><%= t('website.courses.pricing_label') %></th>
                </tr>
              </thead>
              <tbody>
                <% t('website.courses.piano.prices').each do |price| %>
                  <tr>
                    <td><%= price[:duration] %></td>
                    <td><%= price[:price] %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>

            <div class="mt-3">
              <% t('website.courses.piano.info').each do |info| %>
                <p class="small text-muted mb-1">
                  <i class="bi bi-info-circle me-1"></i><%= info %>
                </p>
              <% end %>
            </div>

            <div class="alert alert-warning bg-warning bg-opacity-10 border-warning mt-3 mb-0">
              <small><%= t('website.courses.piano.goal') %></small>
            </div>
          </div>
        </div>
      </div>

      <%# Musical Initiation %>
      <div class="col-lg-6">
        <div class="card h-100 border-warning shadow-sm">
          <div class="card-header bg-warning bg-opacity-10 border-warning">
            <h3 class="mb-0 d-flex align-items-center">
              <i class="bi bi-music-note-beamed me-2 text-warning"></i>
              <%= t('website.courses.initiation.title') %>
            </h3>
          </div>
          <div class="card-body p-4">
            <ul class="list-unstyled mb-4">
              <li class="mb-2">
                <i class="bi bi-people text-warning me-2"></i>
                <strong><%= t('website.courses.age_label') %>:</strong> <%= t('website.courses.initiation.age') %>
              </li>
              <li class="mb-2">
                <i class="bi bi-globe text-warning me-2"></i>
                <strong><%= t('website.courses.languages_label') %>:</strong> <%= t('website.courses.initiation.languages') %>
              </li>
              <li class="mb-2">
                <i class="bi bi-people-fill text-warning me-2"></i>
                <strong><%= t('website.courses.modality_label') %>:</strong> <%= t('website.courses.initiation.modality') %>
              </li>
              <li class="mb-2">
                <i class="bi bi-clock text-warning me-2"></i>
                <strong><%= t('website.courses.duration_label') %>:</strong> <%= t('website.courses.initiation.duration') %>
              </li>
            </ul>

            <p><%= t('website.courses.initiation.description_1') %></p>
            <p><%= t('website.courses.initiation.description_2') %></p>

            <h5 class="d-flex align-items-center mt-4 mb-3">
              <i class="bi bi-currency-euro text-warning me-2"></i>
              <%= t('website.courses.pricing_label') %>
            </h5>
            <div class="alert alert-warning bg-warning bg-opacity-10 border-warning text-center">
              <strong class="fs-5"><%= t('website.courses.initiation.price') %></strong>
            </div>

            <p><%= t('website.courses.initiation.description_3') %></p>

            <div class="mt-3">
              <% t('website.courses.initiation.info').each do |info| %>
                <p class="small text-muted mb-1">
                  <i class="bi bi-info-circle me-1"></i><%= info %>
                </p>
              <% end %>
            </div>

            <div class="alert alert-warning bg-warning bg-opacity-10 border-warning mt-3 mb-0">
              <small><%= t('website.courses.initiation.focus') %></small>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
