<section id="inicio" class="hero-andes">
  <div class="hero-andes__content">
    <div class="container text-center">
      <span class="hero-andes__badge">
        <i class="bi bi-music-note"></i>
        <%= t('website.footer.location') %>
      </span>

      <h1 class="hero-andes__title"><%= t('website.hero.title') %></h1>
      <p class="hero-andes__tagline"><%= t('website.hero.tagline') %></p>
      <p class="hero-andes__desc"><%= t('website.hero.description') %></p>

      <div class="hero-andes__ctas">
        <a href="#cursos" class="btn btn-andes-outline btn-lg">
          <i class="bi bi-music-note-beamed me-2"></i><%= t('website.hero.cta_classes') %>
        </a>
        <a href="#contacto" class="btn btn-andes-outline btn-lg">
          <i class="bi bi-envelope me-2"></i><%= t('website.hero.cta_contact') %>
        </a>
      </div>
      <div class="hero-andes__trial-cta">
        <a href="<%= trial_classes_path %>" class="btn btn-andes-outline btn-lg hero-andes__trial-btn">
          <i class="bi bi-calendar-check me-2"></i><%= t('website.hero.cta_trial') %>
        </a>
      </div>
    </div>
  </div>

  <div class="hero-andes__mountains">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 220" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0,220 L0,140 Q180,50 360,110 Q540,170 720,70 Q900,0 1080,90 Q1260,150 1440,80 L1440,220 Z" fill="rgba(42,37,32,0.06)" />
      <path d="M0,220 L0,160 Q200,90 400,140 Q600,190 800,110 Q1000,40 1200,120 Q1350,170 1440,130 L1440,220 Z" fill="rgba(42,37,32,0.1)" />
      <path d="M0,220 L0,180 Q180,150 400,170 Q620,195 800,160 Q1000,130 1200,165 Q1350,185 1440,170 L1440,220 Z" fill="#faf6ef" />
    </svg>
  </div>
</section>
