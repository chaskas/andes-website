<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
<head>
  <% if ENV['GOOGLE_ANALYTICS_MEASUREMENT_ID'].present? %>
  <meta name="ga-measurement-id" content="<%= ENV['GOOGLE_ANALYTICS_MEASUREMENT_ID'] %>">
  <% end %>
  <title>Andes Academy - <%= t('website.hero.tagline') %></title>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content="<%= t('website.hero.description') %>">

  <%# Open Graph meta tags %>
  <meta property="og:title" content="<%= t('website.seo.og_title') %>">
  <meta property="og:description" content="<%= t('website.seo.og_description') %>">
  <meta property="og:type" content="website">
  <meta property="og:url" content="<%= request.base_url %>">
  <meta property="og:image" content="<%= image_url('website/landscape1.webp') %>">
  <meta property="og:locale" content="<%= { es: 'es_ES', en: 'en_US', de: 'de_DE' }[I18n.locale] %>">

  <%# Twitter Card meta tags %>
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= t('website.seo.og_title') %>">
  <meta name="twitter:description" content="<%= t('website.seo.og_description') %>">
  <meta name="twitter:image" content="<%= image_url('website/landscape1.webp') %>">

  <%# Canonical URL (without locale query params) %>
  <link rel="canonical" href="<%= request.base_url %>">

  <%# Hreflang alternate links for multilingual SEO %>
  <link rel="alternate" hreflang="es" href="<%= request.base_url %>?locale=es">
  <link rel="alternate" hreflang="en" href="<%= request.base_url %>?locale=en">
  <link rel="alternate" hreflang="de" href="<%= request.base_url %>?locale=de">
  <link rel="alternate" hreflang="x-default" href="<%= request.base_url %>">

  <%# Favicon %>
  <link rel="icon" href="/favicon.ico" type="image/x-icon">
  <link rel="apple-touch-icon" href="<%= image_url('website/logo.png') %>">

  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="dns-prefetch" href="https://ga.jspm.io">
  <link rel="preload" href="https://fonts.googleapis.com/css2?family=Cormorant:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Jost:wght@300;400;500;600;700&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link href="https://fonts.googleapis.com/css2?family=Cormorant:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Jost:wght@300;400;500;600;700&display=swap" rel="stylesheet"></noscript>

  <%= render "website/shared/structured_data" %>

  <%= stylesheet_link_tag "website", media: "all" %>
  <%= javascript_importmap_tags "application-website" %>
</head>
<body data-bs-spy="scroll" data-bs-target="#main-navbar">

  <a href="#main-content" class="skip-link"><%= t('website.accessibility.skip_to_content') %></a>

  <%= render "website/shared/navbar" %>

  <main id="main-content">
    <%= yield %>
  </main>

  <%= render "website/shared/footer" %>
  <%= render "website/shared/cookie_consent" %>

  <script>
    (function() {
      var COOKIE_NAME = 'andes_cookie_consent';

      function getCookie(name) {
        var match = document.cookie.match(new RegExp('(^| )' + name + '=([^;]+)'));
        return match ? match[2] : null;
      }

      function setCookie(name, value, days) {
        var d = new Date();
        d.setTime(d.getTime() + (days * 24 * 60 * 60 * 1000));
        document.cookie = name + '=' + value + ';expires=' + d.toUTCString() + ';path=/;SameSite=Lax';
      }

      function loadGA() {
        var gaId = document.querySelector('meta[name="ga-measurement-id"]');
        if (!gaId) return;
        var id = gaId.getAttribute('content');
        var script = document.createElement('script');
        script.async = true;
        script.src = 'https://www.googletagmanager.com/gtag/js?id=' + id;
        document.head.appendChild(script);
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        window.gtag = gtag;
        gtag('js', new Date());
        gtag('config', id, { anonymize_ip: true });
      }

      var consent = getCookie(COOKIE_NAME);
      if (consent === 'accepted') {
        loadGA();
      } else if (!consent) {
        var banner = document.getElementById('cookie-consent-banner');
        if (banner) banner.style.display = 'flex';
      }

      var acceptBtn = document.getElementById('cookie-accept');
      var rejectBtn = document.getElementById('cookie-reject');

      if (acceptBtn) {
        acceptBtn.addEventListener('click', function() {
          setCookie(COOKIE_NAME, 'accepted', 365);
          document.getElementById('cookie-consent-banner').style.display = 'none';
          loadGA();
        });
      }

      if (rejectBtn) {
        rejectBtn.addEventListener('click', function() {
          setCookie(COOKIE_NAME, 'rejected', 365);
          document.getElementById('cookie-consent-banner').style.display = 'none';
        });
      }
    })();
  </script>

</body>
</html>
