<section id="cursos" class="courses-section">
  <div class="container">
    <div class="text-center mb-5 reveal">
      <span class="section-label"><%= t('website.nav.courses') %></span>
      <h2 class="section-title"><%= t('website.courses.title') %></h2>
      <p class="text-muted mt-2"><%= t('website.courses.subtitle') %></p>
    </div>

    <div class="row g-4">
      <%# Piano Lessons %>
      <div class="col-lg-6 reveal">
        <div class="course-card">
          <div class="course-card__photo">
            <%= image_tag "website/landscape3.webp", alt: t('website.courses.piano.title'), class: "course-card__photo-img", loading: "lazy" %>
          </div>
          <div class="course-card__header course-card__header--piano">
            <div class="course-card__icon course-card__icon--terra">
              <i class="bi bi-broadcast"></i>
            </div>
            <h3 class="course-card__title"><%= t('website.courses.piano.title') %></h3>
          </div>
          <div class="course-card__body">
            <div class="course-card__detail">
              <i class="bi bi-people"></i>
              <span><strong><%= t('website.courses.age_label') %>:</strong> <%= t('website.courses.piano.age') %></span>
            </div>
            <div class="course-card__detail">
              <i class="bi bi-globe"></i>
              <span><strong><%= t('website.courses.languages_label') %>:</strong> <%= t('website.courses.piano.languages') %></span>
            </div>
            <div class="course-card__detail">
              <i class="bi bi-music-note"></i>
              <span><strong><%= t('website.courses.modality_label') %>:</strong> <%= t('website.courses.piano.modality') %></span>
            </div>
            <div class="course-card__detail">
              <i class="bi bi-clock"></i>
              <span><strong><%= t('website.courses.duration_label') %>:</strong> <%= t('website.courses.piano.duration') %></span>
            </div>

            <div class="mt-3">
              <p class="course-card__desc"><%= t('website.courses.piano.description_1') %></p>
              <p class="course-card__desc"><%= t('website.courses.piano.description_2') %></p>
            </div>

            <h6 class="d-flex align-items-center mt-4 mb-3" style="font-family: 'Cormorant', serif; font-weight: 600;">
              <i class="bi bi-currency-euro me-2" style="color: var(--andes-terra); font-size: 0.95rem;"></i>
              <%= t('website.courses.pricing_label') %>
            </h6>

            <div class="pricing-grid">
              <% t('website.courses.piano.prices').each do |price| %>
                <div class="price-item">
                  <div class="price-item__duration"><%= price[:duration] %></div>
                  <div class="price-item__price">
                    <% amount, unit = price[:price].split(' ', 2) %>
                    <span class="price-item__number"><%= amount %></span>
                    <span class="price-item__unit"><%= unit %></span>
                  </div>
                </div>
              <% end %>
            </div>

            <div class="mt-3">
              <% t('website.courses.piano.info').each do |info| %>
                <p class="course-info">
                  <i class="bi bi-info-circle"></i>
                  <span><%= info %></span>
                </p>
              <% end %>
            </div>

            <div class="course-goal">
              <%= t('website.courses.piano.goal') %>
            </div>
          </div>
        </div>
      </div>

      <%# Musical Initiation %>
      <div class="col-lg-6 reveal">
        <div class="course-card">
          <div class="course-card__photo">
            <%= image_tag "website/landscape2.webp", alt: t('website.courses.initiation.title'), class: "course-card__photo-img", loading: "lazy" %>
          </div>
          <div class="course-card__header course-card__header--initiation">
            <div class="course-card__icon course-card__icon--gold">
              <i class="bi bi-music-note-beamed"></i>
            </div>
            <h3 class="course-card__title"><%= t('website.courses.initiation.title') %></h3>
          </div>
          <div class="course-card__body">
            <div class="course-card__detail">
              <i class="bi bi-people"></i>
              <span><strong><%= t('website.courses.age_label') %>:</strong> <%= t('website.courses.initiation.age') %></span>
            </div>
            <div class="course-card__detail">
              <i class="bi bi-globe"></i>
              <span><strong><%= t('website.courses.languages_label') %>:</strong> <%= t('website.courses.initiation.languages') %></span>
            </div>
            <div class="course-card__detail">
              <i class="bi bi-people-fill"></i>
              <span><strong><%= t('website.courses.modality_label') %>:</strong> <%= t('website.courses.initiation.modality') %></span>
            </div>
            <div class="course-card__detail">
              <i class="bi bi-clock"></i>
              <span><strong><%= t('website.courses.duration_label') %>:</strong> <%= t('website.courses.initiation.duration') %></span>
            </div>

            <div class="mt-3">
              <p class="course-card__desc"><%= t('website.courses.initiation.description_1') %></p>
              <p class="course-card__desc"><%= t('website.courses.initiation.description_2') %></p>
            </div>

            <h6 class="d-flex align-items-center mt-4 mb-3" style="font-family: 'Cormorant', serif; font-weight: 600;">
              <i class="bi bi-currency-euro me-2" style="color: var(--andes-gold); font-size: 0.95rem;"></i>
              <%= t('website.courses.pricing_label') %>
            </h6>

            <div class="price-single">
              <div class="price-single__amount">
                <% amount, unit = t('website.courses.initiation.price').split(' ', 2) %>
                <span class="price-single__number"><%= amount %></span>
                <span class="price-single__unit"><%= unit %></span>
              </div>
            </div>

            <p class="course-card__desc"><%= t('website.courses.initiation.description_3') %></p>

            <div class="mt-3">
              <% t('website.courses.initiation.info').each do |info| %>
                <p class="course-info">
                  <i class="bi bi-info-circle"></i>
                  <span><%= info %></span>
                </p>
              <% end %>
            </div>

            <div class="course-goal" style="border-left-color: var(--andes-gold); background: linear-gradient(135deg, var(--andes-gold-light), rgba(255,255,255,0.5));">
              <%= t('website.courses.initiation.focus') %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
